{
    "name": "Agent Team — Daily Triage",
    "flow": [
        {
            "id": 1,
            "module": "http:MakeRequest",
            "version": 4,
            "parameters": {
                "tlsType": "",
                "proxyKeychain": "",
                "authenticationType": "noAuth"
            },
            "mapper": {
                "url": "https://ntfy.sh/TODO_NTFY_TOPIC",
                "method": "post",
                "headers": [
                    {"name": "Title", "value": "Agent Team — Daily Triage"},
                    {"name": "Tags", "value": "robot,calendar"},
                    {"name": "Priority", "value": "default"}
                ],
                "contentType": "text/plain",
                "bodyType": "raw",
                "data": "Daily triage time.\n\nCheck QUEUE.md, then run Claude Code locally:\n  cd autosmartweby && claude\n  > vezmi další task z queue\n\nQUEUE.md: https://github.com/Spookybro55/autosmartweby/blob/main/docs/agents/QUEUE.md\nFINDINGS.md: https://github.com/Spookybro55/autosmartweby/blob/main/docs/audits/FINDINGS.md",
                "shareCookies": false,
                "parseResponse": true,
                "allowRedirects": true,
                "stopOnHttpError": true,
                "useNumberAsString": false,
                "useMtls": false
            },
            "metadata": {
                "designer": {"x": 0, "y": 0}
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {"orphans": []},
        "zone": "eu2.make.com",
        "notes": []
    },
    "_setup_notes": {
        "ntfy_topic": "Replace TODO_NTFY_TOPIC in module 1 mapper.url with your ntfy topic suffix (e.g. random 14-char string).",
        "schedule": "After import, in Make UI scenario settings: cron 0 8 * * * Europe/Prague (08:00 daily)."
    }
}
