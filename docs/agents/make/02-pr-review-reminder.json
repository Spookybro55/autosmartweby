{
    "name": "Agent Team — PR Review Reminder",
    "flow": [
        {
            "id": 1,
            "module": "util:GetVariables",
            "version": 1,
            "parameters": {},
            "mapper": {
                "variables": [
                    {"name": "_replace_with", "value": "GitHub → List Pull Requests (owner=Spookybro55, repo=autosmartweby, state=open, limit=50)"}
                ]
            },
            "metadata": {
                "designer": {"x": 0, "y": 0},
                "restore": {}
            }
        },
        {
            "id": 2,
            "module": "http:MakeRequest",
            "version": 4,
            "parameters": {
                "tlsType": "",
                "proxyKeychain": "",
                "authenticationType": "noAuth"
            },
            "mapper": {
                "url": "https://ntfy.sh/autosmartweby-agents-123456789",
                "method": "post",
                "headers": [
                    {"name": "Title", "value": "Agent PR awaiting review"},
                    {"name": "Tags", "value": "warning,git"},
                    {"name": "Priority", "value": "high"}
                ],
                "contentType": "text/plain",
                "bodyType": "raw",
                "data": "Agent PR open > 24h.\n\nReview: https://github.com/Spookybro55/autosmartweby/pulls?q=is%3Aopen+head%3Aagent%2F",
                "shareCookies": false,
                "parseResponse": true,
                "allowRedirects": true,
                "stopOnHttpError": true,
                "useNumberAsString": false,
                "useMtls": false
            },
            "metadata": {
                "designer": {"x": 300, "y": 0}
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {"orphans": []},
        "zone": "eu2.make.com",
        "notes": [
            {
                "moduleIds": [1],
                "content": "<p><strong>Module 1 — REPLACE with GitHub → List Pull Requests.</strong> After import: right-click placeholder → Replace → search 'GitHub' → 'List Pull Requests'. Add edge filter <code>head.ref starts with agent/</code> AND <code>(now - created_at) > 86400000 ms</code>.</p>",
                "isFilterNote": false
            },
            {
                "moduleIds": [2],
                "content": "<p><strong>Module 2 — HTTP → ntfy</strong> (REAL).</p>",
                "isFilterNote": false
            },
            {
                "moduleIds": [],
                "content": "<p><strong>Schedule:</strong> cron <code>0 9,11,13,15,18,21 * * *</code> Europe/Prague. <strong>Ops/měs:</strong> ~180.</p>",
                "isFilterNote": false
            }
        ]
    }
}
