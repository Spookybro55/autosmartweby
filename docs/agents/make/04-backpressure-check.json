{
    "name": "Agent Team — Backpressure Check",
    "flow": [
        {
            "id": 1,
            "module": "util:GetVariables",
            "version": 1,
            "parameters": {},
            "mapper": {
                "variables": [
                    {"name": "_replace_with", "value": "GitHub → List Pull Requests (owner=Spookybro55, repo=autosmartweby, state=open, limit=50)"}
                ]
            },
            "metadata": {
                "designer": {"x": 0, "y": 0},
                "restore": {}
            }
        },
        {
            "id": 2,
            "module": "http:MakeRequest",
            "version": 4,
            "parameters": {
                "tlsType": "",
                "proxyKeychain": "",
                "authenticationType": "noAuth"
            },
            "mapper": {
                "url": "https://ntfy.sh/autosmartweby-agents-123456789",
                "method": "post",
                "headers": [
                    {"name": "Title", "value": "Agent backpressure ⚠"},
                    {"name": "Tags", "value": "warning,no_entry"},
                    {"name": "Priority", "value": "urgent"}
                ],
                "contentType": "text/plain",
                "bodyType": "raw",
                "data": "Agent PR backlog reached threshold (master plan §5).\n\n1. Edit docs/agents/QUEUE.md status → PAUSED.\n2. Triage open PRs.\n3. Flip status → ACTIVE after drain.\n\nhttps://github.com/Spookybro55/autosmartweby/pulls?q=is%3Aopen+head%3Aagent%2F",
                "shareCookies": false,
                "parseResponse": true,
                "allowRedirects": true,
                "stopOnHttpError": true,
                "useNumberAsString": false,
                "useMtls": false
            },
            "metadata": {
                "designer": {"x": 300, "y": 0}
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {"orphans": []},
        "zone": "eu2.make.com",
        "notes": [
            {
                "moduleIds": [1],
                "content": "<p><strong>Module 1 — REPLACE with GitHub → List Pull Requests.</strong> Add edge filter <code>head.ref starts with agent/</code>.</p>",
                "isFilterNote": false
            },
            {
                "moduleIds": [2],
                "content": "<p><strong>Module 2 — HTTP → ntfy</strong> (REAL). After import, Sebastián adds <strong>Tools → Aggregator (count)</strong> + <strong>Router</strong> with filter <code>count >= 5</code> BEFORE this HTTP — so notifications fire only when threshold is crossed.</p>",
                "isFilterNote": false
            },
            {
                "moduleIds": [],
                "content": "<p><strong>Schedule:</strong> cron <code>0 * * * *</code> hourly. <strong>Threshold:</strong> 5 PRs. <strong>Ops/měs:</strong> ~720.</p>",
                "isFilterNote": false
            }
        ]
    }
}
