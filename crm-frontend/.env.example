# CRM Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit secrets.

# --- Google Sheets (read) ---
GOOGLE_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- Apps Script (write) ---
APPS_SCRIPT_WEB_APP_URL=
APPS_SCRIPT_SECRET=

# --- Auth: Session ---
NEXTAUTH_SECRET=           # HMAC signing key for session cookie (min 32 chars)

# --- Auth: Legacy password (fallback) ---
AUTH_PASSWORD=             # Shared password for email+password login
ALLOWED_EMAILS=            # Comma-separated list of allowed emails (e.g. user@gmail.com,admin@example.com)

# --- Auth: Google OAuth ---
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=   # OAuth 2.0 Client ID (visible to browser for GIS SDK)
GOOGLE_OAUTH_CLIENT_ID=               # Same Client ID (server-side for token verification)
