# ============================================================================
# crm-frontend — environment variables (template)
# ============================================================================
# Skopíruj na .env.local pro lokální vývoj. Pro Vercel deploy nastav stejné
# klíče v Project Settings → Environment Variables (Production+Preview+Dev).
#
# Generování secrets:   openssl rand -base64 32
# Plná dokumentace:     docs/PILOT-ENV-VARS.md
# Audit refs:           BLD-001, BLD-003, BLD-004, SEC-016, IN-016
# ============================================================================

# ----- Auth (REQUIRED) ------------------------------------------------------

# HMAC signing key pro session cookie. Min. 32 znaků (KROK 3 přidá fail-fast).
# Generuj: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-replace-me

# Sdílené heslo pro pilot uživatele (4 lidi). Min. 16 znaků doporučeno.
# Generuj: openssl rand -base64 18
AUTH_PASSWORD=your-shared-pilot-password-min-16-chars

# Comma-separated allowlist emailů. ŽÁDNÉ mezery kolem čárek.
# Příklad: alice@example.com,bob@example.com
ALLOWED_EMAILS=user1@example.com,user2@example.com

# ----- Apps Script bridge (REQUIRED for writes) -----------------------------

# URL deployed Apps Script Web App (končí /exec). Z Apps Script Console
# → Deploy → New deployment → Web app → Web app URL.
APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Shared secret pro auth volání AS. MUSÍ být IDENTICKÝ s
# `FRONTEND_API_SECRET` v Apps Script Script Properties.
# Generuj: openssl rand -base64 32
APPS_SCRIPT_SECRET=your-shared-secret-min-32-chars-replace-me

# ----- Google Sheets reads (REQUIRED for real data) -------------------------

# Bez těchto 3 vars (a NODE_ENV=production) frontend padne s explicit error
# (mock-service.ts fail-fast). V dev mode (NODE_ENV !== production) se přepne
# do mock módu s console.warn. Opt-in mock kdykoli: MOCK_MODE=true.

# Service Account email pro read-only přístup do Sheety.
# Z Google Cloud Console → IAM → Service Accounts → JSON key → client_email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service Account private key (PEM). Vlep CELÝ string z JSON, včetně \n
# escape sekvencí. Kód dělá .replace(/\\n/g, '\n').
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Sheet ID — pro pilot TEST sheet (workspace unipong.cz).
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# ----- Preview render webhook (REQUIRED) ------------------------------------

# Shared secret pro Apps Script → /api/preview/render webhook. MUSÍ být
# IDENTICKÝ s `PREVIEW_WEBHOOK_SECRET` v Apps Script Script Properties.
# Generuj: openssl rand -base64 32
PREVIEW_WEBHOOK_SECRET=your-preview-webhook-secret-min-32-chars

# Veřejný base URL pro generované preview URL (bez trailing /).
# Lokálně: http://localhost:3000  Produkce: https://<project>.vercel.app
PUBLIC_BASE_URL=http://localhost:3000

# ----- Optional ------------------------------------------------------------

# Explicit opt-in pro mock data (bypass GOOGLE_* checks). Hodnota: 'true'.
# MOCK_MODE=true
