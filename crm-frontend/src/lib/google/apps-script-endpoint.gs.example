/**
 * ⚠️ This is a SKETCH for onboarding only — NOT a maintained copy.
 *
 * Canonical source: apps-script/WebAppEndpoint.gs (19 actions, see list below)
 * Last synced with WebAppEndpoint.gs at: 1eacdb9
 *
 * If you're implementing a NEW doPost action, READ THE CANONICAL FILE FIRST.
 * This example shows the routing pattern + token check, not all branches.
 *
 * ─────────────────────────────────────────────────────────────────────────
 *  Action contract (request/response shape)
 * ─────────────────────────────────────────────────────────────────────────
 *   Request:  { action: <string>, token: <FRONTEND_API_SECRET>, ...payload }
 *   Response: { ok: <bool>, error?: <string>, details?: <object>, ...result }
 *
 *   Error codes (canonical Czech-labeled set):
 *     - crm-frontend/src/types/scrape.ts:
 *         TRIGGER_SCRAPE_ERROR_CODES, RESOLVE_REVIEW_ERROR_CODES
 *     - Per-handler validation strings ('missing_*', 'invalid_*', '*_not_found')
 *
 * ─────────────────────────────────────────────────────────────────────────
 *  HTTP status mapping (handled by Vercel routes, not by Apps Script)
 * ─────────────────────────────────────────────────────────────────────────
 *   AS returns                              Vercel route returns
 *   ─────────────────                       ────────────────────
 *   { ok: true, ... }                    →  200
 *   { ok: false, error: 'raw_import_not_found' }
 *                                        →  404
 *   { ok: false, error: 'already_resolved' }
 *                                        →  409  (PR #78)
 *   { ok: true, duplicate: true }        →  409  (PR #76 duplicate query)
 *   { ok: false, error: 'rate_limit_exceeded', details: {...} }
 *                                        →  429 + Retry-After header (PR #80)
 *   { ok: false, error: <other> }        →  502 (AS reachable, returned error)
 *   AS unreachable / network error       →  500 / 502
 *
 * ─────────────────────────────────────────────────────────────────────────
 *  Full action list (snapshot at sync commit above)
 * ─────────────────────────────────────────────────────────────────────────
 *  Lead management:
 *    updateLead, assignLead
 *
 *  Preview pipeline (Phase 2):
 *    getPreview, generatePreview, sendEmail
 *
 *  Email templates (B-13):
 *    listTemplates, getTemplate, getTemplateDraft, getTemplateHistory,
 *    saveTemplateDraft, discardTemplateDraft, publishTemplate,
 *    getTemplateAnalytics, regenerateDraft
 *
 *  Scraping pipeline (A-11 + followups):
 *    triggerScrape, ingestScrapedRows, listScrapeHistory,
 *    listPendingReview, resolveReview
 *
 *  Total: 19 actions. Add new ones to apps-script/WebAppEndpoint.gs and
 *  update this comment + the sync commit hash above.
 *
 * ─────────────────────────────────────────────────────────────────────────
 *  Deployment
 * ─────────────────────────────────────────────────────────────────────────
 *  Apps Script editor → Deploy → New deployment → Web App
 *    Execute as:  Me (the deploying account)
 *    Access:      Anyone   (token verification gates real auth)
 *
 *  Required Script Property: FRONTEND_API_SECRET
 *    apps-script/.clasp.json scriptId is TEST by default; do clasp push
 *    only after merge to main, then manually swap scriptId for PROD.
 */

var FRONTEND_SECRET = PropertiesService.getScriptProperties().getProperty('FRONTEND_API_SECRET');

function doPost(e) {
  try {
    var payload = JSON.parse(e.postData.contents);

    // ── Token check (first; rejects unauthenticated calls) ──
    if (!FRONTEND_SECRET || payload.token !== FRONTEND_SECRET) {
      return jsonResponse_({ ok: false, error: 'Unauthorized' });
    }

    // ── Lead management ──
    if (payload.action === 'updateLead')   return handleUpdateLead_(payload);
    if (payload.action === 'assignLead')   return handleAssignLead_(payload);

    // ── Preview pipeline (Phase 2) ──
    if (payload.action === 'getPreview')      return handleGetPreview_(payload);
    if (payload.action === 'generatePreview') return handleGeneratePreview_(payload);
    if (payload.action === 'sendEmail')       return handleSendEmail_(payload);

    // ── Email templates (B-13) ──
    if (payload.action === 'listTemplates')        return handleListTemplates_(payload);
    if (payload.action === 'getTemplate')          return handleGetTemplate_(payload);
    if (payload.action === 'getTemplateDraft')     return handleGetTemplateDraft_(payload);
    if (payload.action === 'getTemplateHistory')   return handleGetTemplateHistory_(payload);
    if (payload.action === 'saveTemplateDraft')    return handleSaveTemplateDraft_(payload);
    if (payload.action === 'discardTemplateDraft') return handleDiscardTemplateDraft_(payload);
    if (payload.action === 'publishTemplate')      return handlePublishTemplate_(payload);
    if (payload.action === 'getTemplateAnalytics') return handleGetTemplateAnalytics_(payload);
    if (payload.action === 'regenerateDraft')      return handleRegenerateDraft_(payload);

    // ── Scraping pipeline (A-11) ──
    if (payload.action === 'triggerScrape')      return handleTriggerScrape_(payload);
    if (payload.action === 'ingestScrapedRows')  return handleIngestScrapedRows_(payload);
    if (payload.action === 'listScrapeHistory')  return handleListScrapeHistory_(payload);
    if (payload.action === 'listPendingReview')  return handleListPendingReview_(payload);
    if (payload.action === 'resolveReview')      return handleResolveReview_(payload);

    return jsonResponse_({ ok: false, error: 'Unknown action: ' + payload.action });

  } catch (err) {
    return jsonResponse_({ ok: false, error: err.message });
  }
}

function jsonResponse_(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

